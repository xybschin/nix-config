#!/usr/bin/env bash
set -euo pipefail
# ---------------------------------------------------------------------------
# hyprland-monitor-profile
# Saves a named monitor profile and triggers Hyprland to re-apply it.
# Usage: script [profile_name]
#   No args: re-applies the last saved profile (or "profile1" on first run).
# ---------------------------------------------------------------------------
readonly STATE_DIR="${XDG_STATE_HOME:-"$HOME/.local/state"}"
readonly STATE_FILE="$STATE_DIR/hyprland-monitor-profile"
mkdir -p "$STATE_DIR"

# ---------------------------------------------------------------------------
# validate_profile <profile>
# ---------------------------------------------------------------------------
validate_profile() {
    case "$1" in
        profile1|profile2|profile3|profile4) ;;
        *)
            printf 'Unknown profile: %s\n' "$1" >&2
            exit 1
            ;;
    esac
}

# ---------------------------------------------------------------------------
# apply_profile <profile>
#   Writes the state file and triggers a full Hyprland reload.
# ---------------------------------------------------------------------------
apply_profile() {
    local profile=$1
    validate_profile "$profile"
    printf '%s\n' "$profile" > "$STATE_FILE"
    hyprctl reload
    sleep 0.5

    if [[ "$profile" == "profile2" ]]; then
        hyprctl keyword monitor "DP-1,disable"
        for ws in $(seq 1 10); do
            hyprctl dispatch "hl.dsp.workspace.move({id = $ws, monitor = \"HDMI-A-1\"})" 2>/dev/null || true
        done
    elif [[ "$profile" == "profile3" || "$profile" == "profile4" ]]; then
        hyprctl keyword monitor "HDMI-A-1,disable"
        for ws in $(seq 1 10); do
            hyprctl dispatch "hl.dsp.workspace.move({id = $ws, monitor = \"DP-1\"})" 2>/dev/null || true
        done
    fi
}

# ---------------------------------------------------------------------------
# main
# ---------------------------------------------------------------------------
main() {
    if [[ $# -eq 0 ]]; then
        if [[ -f "$STATE_FILE" ]]; then
            apply_profile "$(cat "$STATE_FILE")"
        else
            apply_profile "profile1"
        fi
    else
        apply_profile "$1"
    fi

    systemctl --user restart hyprpaper.service
    systemctl --user restart waybar.service
}

main "$@"
